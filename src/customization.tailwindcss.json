{
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss"
      ],
      "files.associations": {
        "*.css": "tailwindcss"
      },
      "settings": {
        "tailwindCSS.experimental.classRegex": [
          ["\\/\\*\\s?tw:\\s?\\*\\/\\s?['\"`]([^'\"`]*)['\"`]"]
        ]
      }
    }
  }
}
